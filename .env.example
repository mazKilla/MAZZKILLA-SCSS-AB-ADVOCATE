# ── SCSS AB Advocate — Environment Variables ──────────────────────────────────
# Copy this file to backend/.env and fill in your values.

# MongoDB connection string
# Local WSL example:  mongodb://localhost:27017
# Atlas cloud example: mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URL=mongodb://localhost:27017

# MongoDB database name (default is fine)
DB_NAME=scss_advocate

# Anthropic API key (required for Claude chat)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# xAI Grok API key (optional — Grok feature; leave blank if not using)
XAI_API_KEY=
